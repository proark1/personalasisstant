# Single-origin gateway for the self-hosted stack. supabase-js calls
# <VITE_SUPABASE_URL>/rest/v1/*, /auth/v1/*, /realtime/v1/*, /functions/v1/* —
# this routes each path prefix to the right Railway service and adds the
# CORS the browser needs.
#
# Required env (set on the Railway service):
#   PORT             provided by Railway
#   POSTGREST_URL    e.g. http://postgrest.railway.internal:3000
#   GOTRUE_URL       e.g. http://gotrue.railway.internal:9999
#   REALTIME_URL     e.g. http://realtime.railway.internal:4000   (optional until Realtime is deployed)
#   EDGE_FUNCTIONS_URL  e.g. http://edge-runtime.railway.internal:9000
#   APP_ORIGIN       your app's origin for CORS, e.g. https://app.example.com.
#                    REQUIRED in production — do NOT use "*". If unset, the
#                    Allow-Origin header is empty, which fails closed (browsers
#                    block cross-origin) rather than allowing any site.

{
	admin off
	auto_https off
}

:{$PORT:8080} {
	# CORS — the SPA talks to this gateway cross-origin. Scope to the app origin
	# via APP_ORIGIN (set on the Railway gateway service). No wildcard default:
	# if APP_ORIGIN is unset the header is empty and cross-origin calls fail
	# closed, instead of silently allowing every site to drive the API.
	header {
		Access-Control-Allow-Origin "{$APP_ORIGIN}"
		Access-Control-Allow-Methods "GET, POST, PATCH, PUT, DELETE, OPTIONS, HEAD"
		Access-Control-Allow-Headers "*"
		Access-Control-Expose-Headers "Content-Range, Content-Profile, Content-Location"
		Access-Control-Max-Age "86400"
		Vary "Origin"
		# Security headers applied to every response (REST/auth/realtime/functions).
		# TLS is terminated at Railway's edge; HSTS still governs the HTTPS the
		# browser sees. No CSP here — it needs per-app tuning (see go-live notes).
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
	@preflight method OPTIONS
	respond @preflight 204

	handle_path /rest/v1/* {
		reverse_proxy {$POSTGREST_URL}
	}
	handle_path /auth/v1/* {
		reverse_proxy {$GOTRUE_URL}
	}
	handle /realtime/v1/* {
		# supabase-js connects to /realtime/v1/websocket, but the realtime
		# server (Phoenix) mounts its socket at /socket/websocket. Rewrite
		# the prefix rather than stripping it (handle_path would leave a bare
		# /websocket, which 404s). reverse_proxy auto-upgrades the WebSocket.
		uri replace /realtime/v1 /socket
		reverse_proxy {$REALTIME_URL}
	}
	handle_path /functions/v1/* {
		# Answer the CORS preflight here at the gateway instead of
		# proxying OPTIONS to the edge runtime. If a function crashes at
		# module load (missing env var, etc.) the dispatcher returns 503;
		# were we proxying the preflight, that 503 would fail the browser's
		# preflight check ("does not have HTTP ok status") and mask the
		# real error. Answering locally keeps CORS working regardless.
		@fnpreflight method OPTIONS
		respond @fnpreflight 204

		# Edge functions can be slow (AI completions, gmail sync, etc.).
		# Default Caddy timeouts (~30s) would cut them off — raise to 5
		# minutes to match the worker timeout in main/index.ts.
		#
		# flush_interval -1 disables response buffering so chat's
		# text/event-stream tokens reach the browser incrementally.
		#
		# header_down strips the functions' own CORS headers: each function
		# sets Access-Control-Allow-Origin via strictAppOrigin(), and the
		# gateway's global header block already sets it. Two values on one
		# response makes the browser reject it, so we keep only the gateway's.
		reverse_proxy {$EDGE_FUNCTIONS_URL} {
			transport http {
				read_timeout 5m
				write_timeout 5m
			}
			flush_interval -1
			header_down -Access-Control-Allow-Origin
			header_down -Access-Control-Allow-Headers
			header_down -Access-Control-Allow-Methods
			header_down -Access-Control-Expose-Headers
			header_down -Access-Control-Allow-Credentials
			header_down -Access-Control-Max-Age
		}
	}
	handle {
		respond "darai gateway ok" 200
	}
}

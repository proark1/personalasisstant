# Single-origin gateway for the self-hosted stack. supabase-js calls
# <VITE_SUPABASE_URL>/rest/v1/*, /auth/v1/*, /realtime/v1/* — this routes each
# path prefix to the right Railway service and adds the CORS the browser needs.
#
# Required env (set on the Railway service):
#   PORT          provided by Railway
#   POSTGREST_URL e.g. http://postgrest.railway.internal:3000
#   GOTRUE_URL    e.g. http://gotrue.railway.internal:9999
#   REALTIME_URL  e.g. http://realtime.railway.internal:4000   (optional until Realtime is deployed)
#   FUNCTIONS_HOST the edge-functions service's PUBLIC domain, e.g.
#                 edge-functions-production-d480.up.railway.app  (bare host, no scheme/port).
#                 We use the public domain rather than the private .railway.internal one
#                 because supabase/edge-runtime binds IPv4-only and Railway's private
#                 network is IPv6-only — private routing can't reach it. The public
#                 domain works, but Railway's edge routes by Host header, so we rewrite
#                 the Host to the upstream domain (see the /functions/v1 block).
#   APP_ORIGIN    your app's origin for CORS, or * (default)

{
	admin off
	auto_https off
}

:{$PORT:8080} {
	# CORS — the SPA talks to this gateway cross-origin. supabase-js uses the
	# Authorization header (no cookies), so a wildcard origin is fine.
	header {
		Access-Control-Allow-Origin "{$APP_ORIGIN:*}"
		Access-Control-Allow-Methods "GET, POST, PATCH, PUT, DELETE, OPTIONS, HEAD"
		Access-Control-Allow-Headers "*"
		Access-Control-Expose-Headers "Content-Range, Content-Profile, Content-Location"
		Access-Control-Max-Age "86400"
		Vary "Origin"
		-Server
	}
	@preflight method OPTIONS
	respond @preflight 204

	handle_path /rest/v1/* {
		reverse_proxy {$POSTGREST_URL}
	}
	handle_path /auth/v1/* {
		reverse_proxy {$GOTRUE_URL}
	}
	handle_path /realtime/v1/* {
		reverse_proxy {$REALTIME_URL}
	}
	handle_path /functions/v1/* {
		# Proxy to the edge-functions public domain over HTTPS. The Host
		# header must match the upstream domain or Railway's edge can't
		# route it (it routes by Host). The functions set their own CORS
		# headers, so strip them on the way back to avoid duplicate
		# Access-Control-* headers (the gateway's global header block
		# already adds them, and browsers reject duplicates).
		reverse_proxy https://{$FUNCTIONS_HOST} {
			header_up Host {$FUNCTIONS_HOST}
			header_down -Access-Control-Allow-Origin
			header_down -Access-Control-Allow-Headers
			header_down -Access-Control-Allow-Methods
			header_down -Access-Control-Expose-Headers
			header_down -Access-Control-Max-Age
		}
	}
	handle {
		respond "darai gateway ok" 200
	}
}

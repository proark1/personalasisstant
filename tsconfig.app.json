{
  "compilerOptions": {
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    // ─── Strict mode rollout, phased ────────────────────────────────
    // Phase 1 (done): noFallthroughCasesInSwitch.
    // Phase A (done): zeroed the type-error baseline; tsc gated in CI.
    // Phase B (done): noImplicitAny — every implicit any now annotated.
    // Phase C (todo): noUnusedLocals + noUnusedParameters (~382 sites).
    // Phase D (todo): strictNullChecks (~135 sites; biggest bug-catcher).
    // Phase E (todo): strict: true to lock it in.
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2020",
    "useDefineForClassFields": true
  },
  "include": [
    "src"
  ]
}
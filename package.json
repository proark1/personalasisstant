{
  "name": "onebrain-assistant",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/assistant-web run dev",
    "build:web": "npm --workspace apps/assistant-web run build",
    "lint:web": "npm --workspace apps/assistant-web run lint",
    "lint:backend": "python -m ruff check services/assistant-runtime/src services/assistant-runtime/tests",
    "smoke:onebrain": "python scripts/smoke_onebrain.py",
    "typecheck:web": "npm --workspace apps/assistant-web run typecheck",
    "test:backend": "python -m pytest services/assistant-runtime/tests",
    "openapi": "python services/assistant-runtime/scripts/export_openapi.py --output packages/assistant-api-contract/openapi.json",
    "generate:api": "npm run openapi && npm --workspace apps/assistant-web run generate:api",
    "verify:phase0": "npm run generate:api && npm run typecheck:web && npm run lint:web && npm run lint:backend && npm run build:web && npm run test:backend"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}

ENVIRONMENT=local
LOG_LEVEL=INFO
SERVICE_NAME=assistant-api

ASSISTANT_API_URL=http://localhost:8000
NEXT_PUBLIC_ASSISTANT_API_URL=http://localhost:8000
ASSISTANT_API_PORT=8000
ASSISTANT_WEB_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Local OneBrain: http://localhost:8080
# Current production OneBrain API: https://onebrain-production-0a16.up.railway.app
ONEBRAIN_API_BASE_URL=https://onebrain-production-0a16.up.railway.app
ONEBRAIN_AVAILABLE=true
ONEBRAIN_CLIENT_MODE=auto
ONEBRAIN_SERVICE_KEY=
ONEBRAIN_ACCOUNT_ID=acct_demo
ONEBRAIN_SPACE_ID=space_demo
ONEBRAIN_TIMEOUT_SECONDS=10

POSTGRES_DB=assistant
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://assistant:assistant_dev_password@postgres:5432/assistant
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Replace before any non-local use. This may be any high-entropy string in local
# development; the SecretProvider derives an encryption key from it.
SECRET_MASTER_KEY=local-dev-change-before-shipping

TELEGRAM_WEBHOOK_SECRET=local-telegram-webhook-secret
WORKER_ID=assistant-worker-local
WORKER_POLL_SECONDS=5
RUN_ONCE=false

GEMINI_API_KEY=

# DarAI — Local environment template.
# Copy to `.env` and fill in. Never commit `.env`.
# Server-side secrets (SUPABASE_SERVICE_ROLE_KEY, GEMINI_API_KEY, etc.)
# belong in the Supabase Edge Functions dashboard, NOT here.

# ── Frontend (Vite — anything VITE_* is bundled into the client) ──────────────
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
# Supabase "publishable" / anon key. Safe to expose to the browser.
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

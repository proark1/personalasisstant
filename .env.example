ENVIRONMENT=local
LOG_LEVEL=INFO

ASSISTANT_API_URL=http://localhost:8000
NEXT_PUBLIC_ASSISTANT_API_URL=http://localhost:8000
ONEBRAIN_API_URL=http://localhost:8080
ONEBRAIN_AVAILABLE=true

POSTGRES_DB=assistant
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant_dev_password
DATABASE_URL=postgresql://assistant:assistant_dev_password@postgres:5432/assistant
REDIS_URL=redis://redis:6379/0

# Replace before any non-local use. This may be any high-entropy string in local
# development; the SecretProvider derives an encryption key from it.
SECRET_MASTER_KEY=local-dev-change-before-shipping

TELEGRAM_WEBHOOK_SECRET=local-telegram-webhook-secret
GEMINI_API_KEY=

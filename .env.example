ENVIRONMENT=local
LOG_LEVEL=INFO
SERVICE_NAME=assistant-api

ASSISTANT_API_URL=http://localhost:8000
NEXT_PUBLIC_ASSISTANT_API_URL=http://localhost:8000
ASSISTANT_API_PORT=8000
ASSISTANT_WEB_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth / session enforcement. OneBrain is the identity authority; minting a session is
# delegated to it. AUTH_IDENTITY_MODE "auto" (default) selects the OneBrain identity
# provider in production/staging (login fails closed with 503 until OneBrain exposes an
# identity endpoint) and a local "stub" provider elsewhere. Set "stub" only for local/dev.
AUTH_IDENTITY_MODE=auto
AUTH_SESSION_TTL_SECONDS=43200

# Local OneBrain: http://localhost:8080
# Current production OneBrain API: https://onebrain-production-0a16.up.railway.app
ONEBRAIN_API_BASE_URL=https://onebrain-production-0a16.up.railway.app
ONEBRAIN_AVAILABLE=true
ONEBRAIN_CLIENT_MODE=http
ONEBRAIN_SERVICE_KEY=
ONEBRAIN_ACCOUNT_ID=acct_demo
ONEBRAIN_SPACE_ID=space_demo
ONEBRAIN_TIMEOUT_SECONDS=10

POSTGRES_DB=assistant
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://assistant:assistant_dev_password@postgres:5432/assistant
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Replace before any non-local use. This may be any high-entropy string in local
# development; the SecretProvider derives an encryption key from it.
SECRET_MASTER_KEY=local-dev-change-before-shipping

TELEGRAM_WEBHOOK_SECRET=local-telegram-webhook-secret
WORKER_ID=assistant-worker-local
WORKER_POLL_SECONDS=5
RUN_ONCE=false

# Google provider connector. Leave empty until an OAuth app and optional Pub/Sub
# topic are created in Google Cloud.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/v1/providers/oauth/google/callback
GOOGLE_PUBSUB_TOPIC=
GOOGLE_WEBHOOK_VERIFICATION_TOKEN=local-google-webhook-token

# Microsoft provider connector. Leave empty until an Entra app registration and
# Graph webhook callback are configured.
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:8000/v1/providers/oauth/microsoft/callback
MICROSOFT_TENANT_ID=common
MICROSOFT_WEBHOOK_CLIENT_STATE=local-microsoft-webhook-state

GEMINI_API_KEY=

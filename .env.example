# DarAI — Local environment template.
# Copy to `.env` and fill in. Never commit `.env`.
# Server-side secrets (SUPABASE_SERVICE_ROLE_KEY, GEMINI_API_KEY, etc.)
# belong on the Railway services (edge-runtime, gateway, gotrue), NOT here.
# See edge-runtime/README.md for the full list.

# ── Frontend (Vite — anything VITE_* is bundled into the client) ──────────────
# Point at the Caddy gateway on Railway — it routes /rest/v1, /auth/v1,
# /realtime/v1, and /functions/v1 to the right backend.
VITE_SUPABASE_PROJECT_ID="darai"
VITE_SUPABASE_URL="https://your-gateway.up.railway.app"
# JWT signed with the shared secret carrying {"role":"anon"}.
# Safe to expose to the browser.
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-jwt"
